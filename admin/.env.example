# NimJump Admin — Environment Variables
# Copy this file to .env and fill in your values.
# Real environment variables always override values here.

# ── Server ────────────────────────────────────────────
# Port this app listens on (npm run dev / npm start). Must match
# ADMIN_PORT in backend/.env so the backend proxy finds it.
ADMIN_PORT=3001
# URL prefix the app is served under (Next.js basePath). Must match
# ADMIN_BASE_PATH in backend/.env.
ADMIN_BASE_PATH=/admin

# ── Backend connection (dev only — see .env.production) ──
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080
NEXT_PUBLIC_GAME_URL=https://nimjump.io
