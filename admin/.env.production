# Production build (npm run build && npm start) is served behind the
# backend at the same origin (http://<host>:8080/admin), so API calls
# should be relative — no separate host/port needed.
# (Dev mode — npm run dev — still falls back to http://localhost:8080
# via the default in src/lib/api.ts, since that's a separate host:port.)
NEXT_PUBLIC_BACKEND_URL=
