# NimJump Backend — Environment Variables
# Copy this file to .env and fill in your values.
# Real environment variables always override values here.

# ── Server ────────────────────────────────────────────
PORT=8080
DB_PATH=./data/db

# ── Replay / Godot headless ────────────────────────────
# Folder containing the replay binary (replay/replay.exe) + replay.zip.
SERVERGAMES_DIR=./replay-verifier
# Explicit path to the replay binary itself. Overrides SERVERGAMES_DIR
# (leave empty for auto-detection from SERVERGAMES_DIR).
GODOT_BIN=
REPLAY_JOB_DIR=./data/replay-jobs
# Number of parallel persistent Godot workers (default: 2).
REPLAY_WORKERS=2

# ── Nimiq ─────────────────────────────────────────────
NIMIQ_MNEMONIC=
NIMIQ_PRIVATE_KEY=
NIMIQ_WALLET_ADDRESS=
NIMIQ_RPC_URL=https://rpc.nimiqwatch.com
NIMIQ_NETWORK=mainnet

# ── Telegram alerts (optional) ────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Balance alert threshold (NIM) ────────────────────
LOW_BALANCE_THRESHOLD=1000.0

# ── Admin panel (served at http://<host>:PORT/ADMIN_BASE_PATH) ──
# Backend is exposed to the public internet, so the admin UI and every
# /backend/admin/* API route are locked behind a login page + session
# cookie (see backend/handlers/admin_session.go). Both values below MUST
# be set, otherwise admin routes stay locked (fail closed).
ADMIN_USERNAME=
ADMIN_PASSWORD=
# Port the Next.js admin app listens on — must match ADMIN_PORT in admin/.env
ADMIN_PORT=3001
# URL prefix admin is served under — must match ADMIN_BASE_PATH in admin/.env
ADMIN_BASE_PATH=/admin
# Optional: full override if the admin app runs on another host. Leave
# empty to auto-build from ADMIN_PORT (http://127.0.0.1:<ADMIN_PORT>).
ADMIN_PROXY_URL=
# Starting the backend automatically sets up AND starts the admin app too,
# as a supervised child process (backend/adminproc.go) — you never run
# anything in admin/ by hand. On first run (or whenever admin/node_modules
# or admin/.next is missing) it runs `npm install` and `npm run build`
# itself before starting it, so a completely fresh checkout works off just
# `go run .`. If the admin process ever crashes, it's restarted
# automatically (with backoff) for as long as the backend keeps running,
# and it's killed cleanly when the backend shuts down. Set to false to
# manage the admin app yourself instead (e.g. a separate process/service).
ADMIN_AUTOSTART=true
# Folder the admin app lives in / its start command is run from. Default
# matches this repo's layout (admin/ next to backend/).
ADMIN_DIR=../admin
# Command run inside ADMIN_DIR to start the admin app, after the backend
# has made sure `npm install` / `npm run build` were run. Use
# "npm run dev" here only for local development (skips the build step —
# dev mode compiles on the fly).
ADMIN_START_CMD=npm start
# If true, rebuilds the admin app (`npm run build`) every single time the
# backend starts, even if a build already exists — useful right after
# pulling new admin code so you never forget to rebuild, at the cost of a
# slower startup. Default false: builds only when no build exists yet.
ADMIN_REBUILD_ON_START=false

# ── Leaderboards & versioning (initial defaults — admin panel's System
# tab can change these later; once changed there, the saved value always
# wins over these env vars) ───────────────────────────────────────────
DAILY_LEADERBOARD_ENABLED=true
WEEKLY_LEADERBOARD_ENABLED=false
# Must match GameVersion.CLIENT_VERSION in game/scripts/GameVersion.gd.
REPLAY_VERSION=1

# ── Cloudflare Pages auto-deploy (admin panel → Deploy tab) ──────────
# All three of TOKEN/ACCOUNT_ID/PROJECT must be set for the Deploy tab
# to allow scheduling a Cloudflare deploy. See backend/.env for where to
# find each value in the Cloudflare dashboard.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_PROJECT=
CLOUDFLARE_EXPORT_DIR=../export
CLOUDFLARE_PAGES_BRANCH=main
